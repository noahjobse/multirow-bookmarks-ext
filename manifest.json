{
  "manifest_version": 3,
  "name": "Multi-Row Bookmarks Bar",
  "version": "1.6.0",
  "description": "Replaces the native bookmarks bar with a clean multi-row version.",
  "permissions": ["bookmarks", "tabs", "activeTab", "scripting", "storage", "favicon"],
  "host_permissions": ["<all_urls>"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "css": ["bookmarks-bar.css"],
      "js": ["utils.js", "bookmarks-bar.js"],
      "run_at": "document_end"
    }
  ],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": ["_favicon/*"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ],
  "icons": {
    "16": "icon128.png",
    "48": "icon128.png",
    "128": "icon128.png"
  }
}
